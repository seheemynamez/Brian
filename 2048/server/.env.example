# 2048 server env (local dev)
# Render production 은 dashboard 에서 직접 설정.

# Backend: 'memory' (default) | 'valkey'
STORE_BACKEND=memory

# Valkey 사용 시 — Aiven 의 Service URI 그대로
# VALKEY_URL=rediss://default:PASSWORD@host:port

# Namespace 분리: omok 의 `omok:prod` 와 격리
VALKEY_KEY_PREFIX=2048:dev

# Pages 도메인 잠금 (prod). 로컬 미설정 시 모두 허용.
# ALLOWED_ORIGINS=https://seheemynamez.github.io

# /i/2048/... share 페이지의 redirect 타깃 (미설정 시 같은 origin /2048/)
# CANONICAL_2048_URL=https://seheemynamez.github.io/Brian/2048/

# 서버 port
PORT=8081
