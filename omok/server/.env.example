# ============================================================
# omok server 환경변수 예시. 실제 사용 시 .env 로 복사 후 값 채움.
# .env 는 .gitignore 에 포함되어 있으니 commit 안 됨.
# Render 배포 시엔 dashboard 의 Environment 탭에 같은 키로 추가.
# ============================================================

# Store backend — memory (기본, 단일 프로세스만) 또는 valkey (Aiven 등 외부 redis-compat 영구화).
STORE_BACKEND=memory

# valkey 활성 시: connection URI (rediss:// 권장 — Aiven 은 기본 TLS).
# Aiven 콘솔 → 해당 서비스 → Overview → "Connection information" → Service URI.
# 일부 인프라는 CA cert 필요 — 그 경우 ioredis 기본 tls 옵션 외에 별도 추가 필요.
VALKEY_URL=rediss://default:PASSWORD@host:port

# valkey 키 namespace prefix. dev/prod 가 같은 Aiven 인스턴스 공유 시 분리 필수.
# 예: 로컬 = 'omok:dev', Render production = 'omok:prod'. 미설정 시 기본 'omok'.
VALKEY_KEY_PREFIX=omok:dev

# ---- 일반 server ----
PORT=8080
# Static asset 루트. ../  → 프로젝트 루트 (omok + 2048 둘 다). .  → omok/server 만.
STATIC_ROOT=..
# Github Pages 같은 외부 origin 만 허용하려면 (콤마 구분). 비우면 모두 허용 (dev).
# ALLOWED_ORIGINS=https://seheemynamez.github.io

# ---- 타이머 (테스트/디버그용 override — 주석은 기본값) ----
# TURN_TIMEOUT_MS=30000                    # 한 수의 제한 시간.
# DISCONNECT_GRACE_MS=90000                # 끊김 후 finalizeAbandon 까지 grace (disconnect + rehydrate 공용).
# SPECTATOR_DISCONNECT_GRACE_MS=30000      # 관전자 끊김 후 dropSession 까지 grace.
# BOT_OFFER_DELAY_MS=10000                 # 큐 진입 후 봇 제안까지 대기 시간.
# HEARTBEAT_INTERVAL_MS=15000              # 좀비 ws 감지 cycle. 2 cycle 무응답 시 terminate.
# EMOTE_COOLDOWN_MS=800                    # 사용자/봇 이모트 발송 최소 간격.

# ---- 봇 워커 풀 (튜닝용) ----
# BOT_WORKER_POOL_SIZE=2                   # bot search 전용 worker 수 (Render free CPU 한도 고려).
# BOT_WORKER_TIMEOUT_MS=22000              # 워커 한 회 search timeout. cfg deadline + margin.

# ---- 데이터 cap ----
# RECENT_GAMES_CAP=100                     # 최근 게임 기록 보존 수 (메모리 + valkey LTRIM).

# ---- 운영 (Render) 전용 ----
# CANONICAL_OMOK_URL=https://seheemynamez.github.io/Brian/omok/

# ---- 비상 우회 (의도된 사용만) ----
# ALLOW_MEMORY_STORE_IN_PROD=1             # NODE_ENV=production 에서 memory store 허용 (사고 방지 가드 우회).
